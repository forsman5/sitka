[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/ui/game_over.gd" id="1_game_over"]

[sub_resource type="StyleBoxFlat" id="PanelStyle_1"]
bg_color = Color(0.08, 0.08, 0.1, 0.95)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.3, 0.3, 0.4, 0.8)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_left = 4
corner_radius_bottom_right = 4

[node name="GameOver" type="CanvasLayer"]
layer = 20
script = ExtResource("1_game_over")

[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.08, 0.12, 1)

[node name="Panel" type="Panel" parent="."]
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -115.0
offset_right = 150.0
offset_bottom = 115.0
theme_override_styles/panel = SubResource("PanelStyle_1")

[node name="VBox" type="VBoxContainer" parent="Panel"]
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 20.0
offset_top = 20.0
offset_right = -20.0
offset_bottom = -20.0
theme_override_constants/separation = 16

[node name="TitleLabel" type="Label" parent="Panel/VBox"]
text = "GAME OVER"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32

[node name="SubLabel" type="Label" parent="Panel/VBox"]
text = "All settlers lost — not enough gold to recruit more."
horizontal_alignment = 1
autowrap_mode = 3
modulate = Color(0.65, 0.65, 0.75, 1)
theme_override_font_sizes/font_size = 11

[node name="ReturnButton" type="Button" parent="Panel/VBox"]
text = "Return to Menu"

[node name="LoadButton" type="Button" parent="Panel/VBox"]
text = "Load Game"

[connection signal="pressed" from="Panel/VBox/ReturnButton" to="." method="_on_return_pressed"]
[connection signal="pressed" from="Panel/VBox/LoadButton" to="." method="_on_load_pressed"]
